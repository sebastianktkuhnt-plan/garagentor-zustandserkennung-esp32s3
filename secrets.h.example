// ===========================================================================
//  secrets.h.example  –  VORLAGE für geheime Zugangsdaten
// ---------------------------------------------------------------------------
//  So benutzen:
//    1) Diese Datei kopieren und die Kopie in  "secrets.h"  umbenennen.
//    2) In secrets.h die ECHTEN Werte eintragen.
//
//  Die Datei "secrets.h" steht in .gitignore und wird daher NICHT auf GitHub
//  hochgeladen -> deine echten Zugangsdaten bleiben privat. Diese Vorlage
//  (secrets.h.example) enthält nur Platzhalter und darf eingecheckt werden.
// ===========================================================================
#pragma once

// WLAN-Zugangsdaten (Achtung: ESP32-S3 kann nur 2,4 GHz!)
#define GEHEIM_WLAN_SSID     "MeinWLAN"
#define GEHEIM_WLAN_PASSWORT "MeinWLANPasswort"

// Optionales OTA-Passwort ("" = kein Passwort)
#define GEHEIM_OTA_PASSWORT  ""
